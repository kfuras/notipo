# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://blogcompiler:localdev@localhost:5432/blogcompiler

# 64-char hex string: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Admin API key (used for /api/admin/* routes)
API_KEY=change-me-in-production

# ─── Services ────────────────────────────────────────────────────────────────
IMAGE_SERVICE_URL=http://localhost:8100
PORT=3000
LOG_LEVEL=info

# ─── VPS / Traefik deployment (docker-compose.prod.yml only) ─────────────────
# Your public domain — must have an A record pointing to the VPS IP
DOMAIN=api.yourdomain.com
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com
# Postgres password used by the postgres container (prod only)
DB_PASSWORD=change-me-in-production

# ─── Seed configuration (used by: npx prisma db seed) ────────────────────────
SEED_TENANT_NAME=My Blog
SEED_TENANT_SLUG=myblog
SEED_OWNER_EMAIL=owner@example.com
# API key for the owner user (defaults to API_KEY above if omitted)
SEED_API_KEY=

# Notion status value that triggers the publish pipeline
SEED_NOTION_TRIGGER_STATUS=Post to Wordpress

# WordPress tag name → ID mapping (find IDs in WP Admin → Posts → Tags)
# Referenced by name in SEED_CATEGORIES below
SEED_WP_TAGS={"tech":200030,"featured":100013}

# Categories — one per line, format:  Name | WP Category ID | tag names | background image
#   WP Category ID : WP Admin → Posts → Categories
#   tag names      : comma-separated names from SEED_WP_TAGS above
#   background     : filename in image-service/category-images/  OR a full https:// URL
SEED_CAT_1=Automation    | 200027 | |automation.png
SEED_CAT_2=Azure Cloud   | 100011 | |azure-cloud.png
SEED_CAT_3=Cybersecurity | 200026 | |cybersecurity.png
SEED_CAT_4=Homelab       | 200028 | |homelab.png
SEED_CAT_5=IaC           | 100012 | |iac.png
SEED_CAT_6=Microsoft 365 | 200023 | |microsoft-365.png
# SEED_CAT_7=AI            | 6      | |ai.png  ← add ai.png to image-service/category-images/ first
