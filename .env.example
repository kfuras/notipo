# Connection string for PostgreSQL (local dev only)
# On VPS setup this is overridden by docker-compose.prod.yml using DB_PASSWORD and host "postgres"
DATABASE_URL=postgresql://pressflow:localdev@localhost:5432/pressflow

# Secret key used to encrypt stored Notion and WordPress credentials (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Admin API key (used for /api/admin/* routes)
# Generate with: openssl rand -hex 16
API_KEY=change-me-in-production

PORT=3000
LOG_LEVEL=info

# ─── Notion webhooks (optional, replaces polling) ───────────────────────────
# Set up a webhook subscription in your Notion integration settings, pointing to
# {YOUR_DOMAIN}/api/notion/webhook with the page.content_updated event type.
# On first request Notion sends a verification_token — check your app logs and
# paste it here, then verify in the Notion dashboard.
NOTION_WEBHOOK_SECRET=

# ─── VPS / Traefik deployment (docker-compose.prod.yml only) ─────────────────
# Your public domain — must have an A record pointing to the VPS IP
DOMAIN=api.yourdomain.com
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com
# Postgres password used by the postgres container (prod only)
# Generate with: openssl rand -hex 16
DB_PASSWORD=change-me-in-production

# ─── Initial setup ────────────────────────────────────────────────────────────
# Runs automatically on startup (alongside DB migrations).
# Update these values before your first deploy — they create your first blog account.
SEED_TENANT_NAME=My Blog
SEED_TENANT_SLUG=myblog
SEED_OWNER_EMAIL=owner@example.com
# API key for the owner user — this is what you use to call the API.
# If left blank, falls back to API_KEY above.
SEED_API_KEY=

# Notion status value that triggers the publish pipeline
SEED_NOTION_TRIGGER_STATUS=Post to Wordpress
